# Project Cortex — Configuration Template
# Copy to cortex.yaml and customize

system:
  hostname: cortex
  log_level: INFO  # DEBUG, INFO, WARNING, ERROR
  data_dir: /opt/cortex/data
  timezone: UTC  # Set to your timezone

hal:
  # IPC: ZeroMQ pub/sub and req/rep. Topic convention: {service}.{event_type}
  # e.g., power.state_changed, button.gesture, npu.model_loaded, audio.level
  npu:
    device_id: 0
    axcl_json: /etc/axcl.json
    thermal_throttle_temp: 75  # °C
    thermal_shutdown_temp: 85  # °C
  audio:
    card_name: wm8960sound  # From aplay -l
    sample_rate: 16000
    channels: 1
    format: S16_LE
    volume: 80  # 0-100
  display:
    brightness: 80  # 0-100
    idle_timeout: 30  # seconds before dimming
    orientation: 0  # 0, 90, 180, 270
  camera:
    enabled: false  # Enable when CSI camera module attached
    # Uses libcamera/picamera2 (CSI interface — Freenove, Raspberry Pi Camera, etc.)
    resolution: [640, 480]  # Width x height for VLM input
    format: jpeg
    quality: 85  # JPEG quality (0-100)
  power:
    pisugar_socket: /tmp/pisugar-server.sock
    low_battery_threshold: 15  # %
    critical_battery_threshold: 5  # %
    sleep_on_battery_idle: 300  # seconds
    profiles:
      mains:
        llm_profile: chat  # Full Qwen3-1.7B
        polling_multiplier: 1.0
        display_brightness: 80
      battery:
        llm_profile: quick  # Qwen3-0.6B — reduced power
        polling_multiplier: 2.0  # Half frequency
        display_brightness: 50
      low_battery:
        llm_profile: quick
        polling_multiplier: 4.0  # Quarter frequency
        display_brightness: 30
      critical:
        llm_profile: null  # Regex-only, no LLM inference
        polling_multiplier: 0  # Polling off
        display_brightness: 10

voice:
  activation_mode: button  # button (default — both Pi and Web UI)
  # No VAD, no wake word — both physical Pi and Web UI use explicit button control for recording.
  # Pi: hardware button (GPIO 11) hold-to-talk.
  # Web UI: software record button (hold-to-talk or click-start/click-stop).
  max_recording_duration: 30  # seconds — safety limit for recording length
  session:
    idle_timeout: 300  # seconds before session ends (matches memory extraction timeout)
    farewell_patterns: ["goodbye", "that's all", "thanks i'm done", "see you later"]
  streaming:
    min_chunk_tokens: 8  # Minimum tokens before TTS (avoid tiny fragments)
    crossfade_ms: 10  # Audio crossfade between chunks to prevent pops
    max_queue_depth: 5  # Max TTS chunks queued ahead of playback
  error_recovery:
    asr_retry_prompt: true  # "I didn't catch that" on empty/low-confidence ASR
    llm_retry_count: 1  # Retries before fallback provider
    tts_fallback_lcd: true  # Show text on LCD if TTS fails
  asr:
    # Provider chain — tries in order. Default: local NPU only.
    providers: [axcl]
    axcl: { model: sensevoice, language: en }
    # openai: { model: whisper-1 }  # Uncomment to enable OpenAI Whisper API fallback
    # google: { model: latest_long }  # Uncomment for Google Cloud STT
  tts:
    # Provider chain — tries in order. Default: local NPU only.
    providers: [axcl]
    axcl:
      model: kokoro
      voice: af_heart  # Kokoro voice ID (e.g., af_heart, am_adam, bf_emma)
      speed: 1.0
      sample_rate: 24000  # Kokoro native output rate
      max_chunk_tokens: 96  # axmodel constraint — sentences split at this limit
    # openai: { model: tts-1, voice: nova }  # Uncomment for OpenAI TTS fallback
    # google: { model: en-US-Neural2-F }  # Uncomment for Google Cloud TTS
  latency_budget:
    asr_max_ms: 500
    tts_first_audio_ms: 200

button:
  # Whisplay HAT single button (GPIO 11, active low)
  gpio_pin: 11
  debounce_ms: 50
  gestures:
    hold:
      min_duration_ms: 300  # Press > 300ms = push-to-talk
      action: push_to_talk  # Record while held, ASR on release
    double_click:
      max_gap_ms: 400  # Two presses within 400ms
      action: camera_capture  # Capture image → VLM analysis
    single_click:
      delay_ms: 400  # Wait 400ms to rule out double-click
      action: confirm  # Approve pending action; repeat last response if idle
    long_press:
      min_duration_ms: 2000  # Press > 2s
      action: cancel  # Deny pending action; interrupt current operation
    triple_click:
      max_gap_ms: 600  # Three presses within 600ms
      action: system_menu  # Cycle status screens

# --- Model Providers ---
# Configure inference backends. Default: axcl (local NPU) only.
# Enable additional providers to use cloud LLMs or remote servers.
# API keys stored in .env file (gitignored), never here.
providers:
  axcl:
    enabled: true  # Local NPU — always available when hardware present
    device_id: 0

  ollama:
    enabled: false
    base_url: "http://192.168.1.100:11434"  # Remote Ollama server
    connect_timeout: 5  # seconds
    # allow_sensitive_data: false  # Strip memory/personal data before sending

  openai:
    enabled: false
    # API key: OPENAI_API_KEY in .env
    default_model: gpt-4o-mini
    connect_timeout: 10
    # allow_sensitive_data: false

  anthropic:
    enabled: false
    # API key: ANTHROPIC_API_KEY in .env
    default_model: claude-sonnet-4-6
    connect_timeout: 10
    # allow_sensitive_data: false

  google:
    enabled: false
    # API key: GOOGLE_AI_API_KEY in .env
    default_model: gemini-2.0-flash
    connect_timeout: 10
    # allow_sensitive_data: false

  xai:
    enabled: false
    # API key: XAI_API_KEY in .env
    base_url: "https://api.x.ai/v1"
    default_model: grok-3-mini
    connect_timeout: 10
    # allow_sensitive_data: false

  openai_compatible:
    enabled: false
    base_url: ""  # Any OpenAI-compatible endpoint (vLLM, LiteLLM, TGI, etc.)
    # Optional API key: CUSTOM_LLM_API_KEY in .env
    default_model: ""
    connect_timeout: 10
    # allow_sensitive_data: false

# --- Reasoning Core ---
# Each profile specifies a provider chain (tried in order) with per-provider model config.
# Default: all profiles route to axcl (local NPU) only.
reasoning:
  default_profile: chat
  max_tokens: 512  # Default max generation tokens
  temperature: 0.7
  system_prompt_version: v1

  profiles:
    chat:
      providers: [axcl]
      axcl: { model: qwen3-1.7b, mode: non_thinking }
      # ollama: { model: qwen3:8b }  # Uncomment to add Ollama fallback
      # openai: { model: gpt-4o-mini }
    reason:
      providers: [axcl]
      axcl: { model: qwen3-1.7b, mode: thinking }
      # anthropic: { model: claude-sonnet-4-6 }
    code:
      providers: [axcl]
      axcl: { model: qwen3-1.7b, mode: thinking }
    quick:
      providers: [axcl]
      axcl: { model: qwen3-0.6b, mode: non_thinking }
    vision_quick:
      providers: [axcl]
      axcl: { model: smolvlm2-500m }
      # openai: { model: gpt-4o }
    vision_detail:
      providers: [axcl]
      axcl: { model: internvl3-1b }
    vision_advanced:
      providers: [axcl]
      axcl: { model: qwen2.5-vl-3b }
    fallback:
      # Cloud-only profile — used when local models can't handle the task
      providers: [openai, anthropic]
      openai: { model: gpt-4o-mini }
      anthropic: { model: claude-sonnet-4-6 }

  fallback:
    circuit_breaker_failures: 3  # Skip provider after N consecutive failures
    circuit_breaker_reset_seconds: 60  # Re-enable after this cooldown

agent:
  orchestrator:
    token_budget: 370  # Max tokens for classifier call
    pattern_routing: true  # Try regex/keyword match before LLM call
    fallback_agent: general  # When no confident match
  super_agents:
    config_dir: config/agents  # YAML agent definitions
    max_llm_calls: 4  # Default per-task limit
    default_model_profile: chat  # Profile from reasoning.profiles
    # Context management is provider-managed — no artificial token budgets here
  utility_agents:
    enabled: true  # Pure deterministic dispatch
  action_engine:
    templates_dir: config/actions  # YAML action templates
    default_timeout: 30  # seconds per action execution
    max_retries: 2
    sandbox: bubblewrap  # For untrusted/dynamic handlers
    sandbox_max_memory_mb: 256
    sandbox_max_cpu_seconds: 30
  cognitive_tools:
    enabled: [memory_query, knowledge_search, system_info, file_read, calendar_query, email_query, contact_lookup]
    # web_search and device_state enabled when network/IoT configured
  factory:
    enabled: false  # Enable in Phase 4
    require_approval: true  # Tier 3 approval for new agents/templates
    auto_persist: false  # Require user approval to save
  # tool_call_format: auto-detected from active provider (see §4.3.2 Tool Calling Adaptation)
  mcp:
    client:
      servers_config: config/mcp_servers.yaml  # External MCP server definitions
      connect_timeout: 5  # seconds per server
      default_permission_tier: 2  # For discovered external tools
    server:
      enabled: false  # Enable in Phase 3
      # Exposed on FastAPI server (same host:port as web UI)
      expose_cognitive_tools: true
      expose_action_templates: true  # Respects permission tiers
  a2a:
    client:
      enabled: false  # Enable in Phase 3
      discovery_urls: []  # URLs to check for Agent Cards
      connect_timeout: 5  # seconds
      default_permission_tier: 2  # For discovered external agents
    server:
      enabled: false  # Enable in Phase 3
      # Agent Card served at /.well-known/agent.json on FastAPI server
      expose_agents: [general, home, research, pim, planner]

clarification:
  enabled: true
  confidence_threshold: 0.6  # Below this, orchestrator requests clarification before routing
  max_rounds: 2  # Max clarification exchanges per user turn
  slot_filling:
    enabled: true
    model_profile: quick  # Use Qwen3-0.6B for fast slot-filling prompts
  disambiguation:
    max_options: 3  # "Did you mean X, Y, or Z?"

security:
  tier_0_auto: true
  tier_1_log: true
  tier_2_require_approval: true
  tier_3_require_confirmation_and_reason: true
  approval_timeout: 60  # seconds
  default_deny_on_timeout: true
  guest_mode:
    enabled: false  # Activated by primary user for visitors
    max_permission_tier: 0  # Guests restricted to Tier 0 only
    disable_memory_injection: true  # Privacy: no personal memories in guest context
    disable_iot: true  # No smart home control for guests
    session_timeout: 1800  # 30 min guest session limit
  audit:
    enabled: true
    retention_days: 90
    format: jsonl  # jsonl, sqlite
  network:
    default_policy: deny
    allowed_domains: []  # Populated by user
    local_network_access: true  # For IoT
    tls_minimum: "1.3"
  sandbox:
    engine: bubblewrap  # bubblewrap, podman
    scratch_dir: /opt/cortex/data/sandbox

memory:
  working:
    summary_interval: 3  # Generate rolling summary every N exchanges
    summary_max_tokens: 100  # Max tokens for rolling summary generation
  short_term:
    max_conversations: 100
    retention_days: 30
  long_term:
    enabled: true
    embedding_model: all-MiniLM-L6-v2  # ONNX model, runs on CPU (~22MB)
    embedding_dimensions: 384
    max_entries: 10000
    similarity_threshold: 0.3  # Minimum cosine similarity for auto-injection
    dedup_threshold: 0.85  # Above this = duplicate (skip or supersede)
    auto_inject_count: 3  # Memories to auto-inject per prompt (scaled by provider context)
  episodic:
    enabled: true
    max_entries: 5000
  extraction:
    idle_timeout: 300  # Seconds of inactivity before post-session fact extraction
    regex_patterns: true  # Catch "remember that...", "my name is..." immediately
  knowledge:
    enabled: false  # Enable in Phase 4
    watch_dir: data/knowledge  # Watched directory for document ingestion
    chunk_size_tokens: 200
    chunk_overlap_tokens: 50
    max_documents: 100
    supported_formats: [txt, md, pdf, html]
  encryption:
    enabled: true
    algorithm: aes-256-gcm

web:
  host: "0.0.0.0"  # Will be restricted by nftables
  port: 8080
  auth:
    enabled: true  # Phase 1-2: no auth on LAN. Phase 3+: bcrypt password + session cookie.
    # password_hash set via scripts/setup.sh (bcrypt, stored in .env as CORTEX_PASSWORD_HASH)
    session:
      timeout_local: 3600  # seconds (1h for LAN clients)
      timeout_remote: 1800  # seconds (30min for remote/HTTPS clients)
      cookie_name: cortex_session
      cookie_secure: false  # Set true when behind HTTPS reverse proxy
      cookie_samesite: strict  # CSRF protection
    totp:
      enabled: false  # Optional TOTP 2FA for remote access (Phase 3+)
      # Secret set via scripts/setup.sh, stored in .env as CORTEX_TOTP_SECRET
    csrf:
      enabled: true  # Double-submit token + SameSite=Strict
    api_key:
      enabled: false  # For MCP/A2A integrations (Phase 3+)
      # Key stored in .env as CORTEX_API_KEY
  cors_origins: []  # Restrict to specific origins if needed

scheduling:
  db_path: data/schedules.db  # SQLite — persists timers/reminders across reboots
  max_active_timers: 20
  max_active_reminders: 100
  snooze_duration: 600  # seconds (10 min default snooze)
  max_snoozes: 3

notifications:
  dnd:
    enabled: false  # Do Not Disturb mode
    start_hour: 22  # 10 PM
    end_hour: 7  # 7 AM
    override_p4: true  # P4 (interruptive) still fires during DND
  default_priorities:
    timer_complete: 2  # P2 — chime + LCD
    reminder_due: 3  # P3 — spoken announcement
    smart_home_alert: 1  # P1 — visual only
    system_health: 2  # P2 — chime + LCD
    approval_timeout: 1  # P1 — visual only

health:
  enabled: true
  endpoint: /api/health  # No auth required on local network
  poll_intervals:
    npu: 5  # seconds
    cpu: 10
    memory: 30
    storage: 60
    battery: 30
    network: 60
    services: 10
  watchdog:
    heartbeat_interval: 10  # seconds
    systemd_watchdog_sec: 30
    max_restarts: 3
    restart_window: 300  # seconds (5 min)
  thresholds:
    npu_throttle_temp: 75  # °C — reduce generation speed
    npu_shutdown_temp: 85  # °C — emergency model unload
    cpu_throttle_temp: 80
    ram_warning_pct: 85
    disk_warning_pct: 90
    battery_low_pct: 15
    battery_critical_pct: 5

iot:
  enabled: false  # Enable in Phase 5
  mqtt:
    broker: ""  # e.g., localhost or HA IP
    port: 1883
    username: ""
    password: ""
  homeassistant:
    url: ""  # e.g., http://homeassistant.local:8123
    token: ""  # Long-lived access token

# --- External Services (PIM) ---
# Calendar, messaging, email, and task integrations.
# All services optional and disabled by default. API keys/passwords in .env.
external_services:
  calendar:
    enabled: false
    provider: caldav  # caldav, google, mcp
    caldav:
      url: ""  # e.g., http://localhost:5232 (Radicale self-hosted)
      username: ""
      # password in .env: CALDAV_PASSWORD
    # google:
    #   calendar_id: primary
    #   # credentials in .env: GOOGLE_CALENDAR_CREDENTIALS
  messaging:
    enabled: false
    provider: ntfy  # ntfy, pushover, matrix
    ntfy:
      server: "https://ntfy.sh"  # or self-hosted URL
      default_topic: cortex
      # token in .env: NTFY_TOKEN (optional for self-hosted)
    # pushover:
    #   # keys in .env: PUSHOVER_USER_KEY, PUSHOVER_APP_TOKEN
    #   default_priority: 0  # -2 to 2
    # matrix:
    #   homeserver: ""
    #   room_id: ""
    #   # token in .env: MATRIX_ACCESS_TOKEN
  email:
    enabled: false
    imap:
      server: ""
      port: 993
      use_ssl: true
      username: ""
      # password in .env: EMAIL_PASSWORD
    smtp:
      server: ""
      port: 587
      use_tls: true
      username: ""
      from_address: ""
      # password in .env: SMTP_PASSWORD
  tasks:
    enabled: false
    provider: caldav_vtodo  # caldav_vtodo, todoist
    # Todoist API key in .env: TODOIST_API_KEY
  contacts:
    enabled: true  # Local-only contact store (no external provider required)
    db_path: data/contacts.db
    fuzzy_match_threshold: 0.7  # Name matching sensitivity (0-1)
    # Optional: CardDAV sync (Phase 5)
    # carddav:
    #   enabled: false
    #   url: ""  # e.g., http://localhost:5232 (Radicale)
    #   username: ""
    #   # password in .env: CARDDAV_PASSWORD

# --- Wyoming Protocol Bridge ---
# Expose Cortex's ASR/TTS to Home Assistant as Wyoming services.
wyoming:
  enabled: false  # Enable in Phase 5
  stt:
    enabled: true  # Expose SenseVoice as Wyoming STT provider
    port: 10300
  tts:
    enabled: true  # Expose Kokoro as Wyoming TTS provider
    port: 10200
  satellite:
    enabled: false  # Optional: act as Wyoming satellite (HA orchestrates)
    ha_host: ""  # Home Assistant host for satellite mode

# --- Proactive Intelligence ---
# System-initiated interactions based on learned patterns and context.
proactive:
  enabled: false  # Enable in Phase 4-5
  think_interval: 300  # Seconds between idle "think" loops
  morning_briefing:
    enabled: false
    learned_time: true  # Learn wakeup time from episodic memory
    fallback_time: "07:00"  # If no pattern detected yet
    include: [weather, calendar, reminders]
  routine_suggestions:
    enabled: false
    min_occurrences: 5  # Suggest automation after N detected repetitions
